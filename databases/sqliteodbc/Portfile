                    size    1002929

# XXX: Driver manager neutrality?
depends_run         port:unixODBC

patchfiles          sqliteodbc-0.99991-Fix-too-many-args-to-gpps-compilation-error.patch \
                    sqliteodbc-0.99991-Fix-incompatible-pointer-compilation-error.patch

# Build system crimes begin here
depends_build-append    port:zlib \
                        port:libxml2 \
                        port:sqlite3 \
                        port:unixODBC

# Don't autoreconf, the build system is a horror show, just update config.guess
# use_autoreconf          yes
#autoreconf.args         -fiv .

platform darwin arm {
    depends_build-append    port:automake

    post-patch {
        # Use newer config.guess and config.sub to support Apple Silicon.
        set automake_dirs [glob -directory ${prefix}/share automake-*]
        set automake_dir [lindex [lsort -command vercmp $automake_dirs] end]
        copy -force ${automake_dir}/config.guess ${automake_dir}/config.sub \
            ${worksrcpath}
    }
}

configure.args-append   --with-sqlite3=${prefix} --with-odbc=${prefix} --with-libxml2=${prefix}/bin/xml2-config

